{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/coverage/**",
    "**/test-results/**",
    "docs/**",
    "examples/**"
  ]
}
