{
  "name": "@oaslananka/atlas",
  "version": "1.0.0",
  "description": "npm Registry for MCP Servers — discover, compare, install, and trust any MCP server",
  "license": "Apache-2.0",
  "author": "oaslananka <oaslananka@users.noreply.github.com>",
  "homepage": "https://github.com/oaslananka/mcp-suite#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/mcp-suite.git",
    "directory": "packages/atlas"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-suite/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "atlas": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "registry",
    "discovery",
    "npm-registry",
    "mcp-server",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json && pnpm run build:ui",
    "build:ui": "vite build --config ui/vite.config.ts",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --tsconfig tsconfig.build.json",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src ui/src",
    "clean": "rimraf dist ui/dist"
  },
  "dependencies": {
    "@oaslananka/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
