{
  "name": "@oaslananka/sentinel",
  "version": "1.0.0",
  "description": "Zero-Trust MCP Security Layer — Policy, audit, PII masking, spend control",
  "license": "Apache-2.0",
  "author": "oaslananka <oaslananka@users.noreply.github.com>",
  "homepage": "https://github.com/oaslananka/mcp-suite#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/mcp-suite.git",
    "directory": "packages/sentinel"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-suite/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "mcpName": "io.github.oaslananka/sentinel",
  "main": "dist/index.js",
  "bin": {
    "sentinel": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "server.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "security",
    "proxy",
    "pii",
    "audit",
    "zero-trust",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@oaslananka/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  }
}
