{
  "name": "@oaslananka/observatory",
  "version": "1.0.0",
  "description": "Full observability for MCP — traces, metrics, costs, and anomalies",
  "license": "Apache-2.0",
  "author": "oaslananka <oaslananka@users.noreply.github.com>",
  "homepage": "https://github.com/oaslananka/mcp-suite#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/mcp-suite.git",
    "directory": "packages/observatory"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-suite/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "observatory": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "observability",
    "opentelemetry",
    "metrics",
    "tracing",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json && pnpm run build:ui",
    "build:ui": "vite build --config ui/vite.config.ts",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --tsconfig tsconfig.build.json",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src ui/src",
    "clean": "rimraf dist ui/dist"
  },
  "dependencies": {
    "@oaslananka/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.3"
  }
}
