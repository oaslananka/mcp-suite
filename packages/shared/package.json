{
  "name": "@oaslananka/shared",
  "version": "1.0.0",
  "description": "Shared MCP types, JSON-RPC utils, logger, test helpers",
  "license": "Apache-2.0",
  "author": "oaslananka <oaslananka@users.noreply.github.com>",
  "homepage": "https://github.com/oaslananka/mcp-suite#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/mcp-suite.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-suite/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "jsonrpc",
    "ai-tools",
    "llm-tools"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format esm,cjs --watch --tsconfig tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  }
}
