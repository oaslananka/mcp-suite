{
  "name": "@oaslananka/forge",
  "version": "1.0.0",
  "description": "Chain MCP tools into declarative pipelines — the Unix pipe for MCP",
  "license": "Apache-2.0",
  "author": "oaslananka <oaslananka@users.noreply.github.com>",
  "homepage": "https://github.com/oaslananka/mcp-suite#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/mcp-suite.git",
    "directory": "packages/forge"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-suite/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forge": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "pipeline",
    "workflow",
    "orchestration",
    "ai-automation",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "build:ui": "vite build",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@oaslananka/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "expr-eval-fork": "3.0.3",
    "express": "^4.19.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.3"
  }
}
