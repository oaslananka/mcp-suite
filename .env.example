# Shared
NODE_ENV=development
LOG_LEVEL=info

# Forge
FORGE_DB_PATH=./data/forge.sqlite
FORGE_API_TOKEN=
FORGE_ALLOWED_ORIGINS=http://localhost:4000
FORGE_WS_PATH=/ws
FORGE_WS_ALLOWED_CATEGORIES=runs,pipelines,system
FORGE_WS_ALLOW_MISSING_ORIGIN=false
FORGE_WS_IDLE_TIMEOUT_MS=60000
FORGE_WS_PING_INTERVAL_MS=30000
FORGE_WS_MAX_CONNECTIONS=100
FORGE_WS_MAX_CONNECTIONS_PER_PRINCIPAL=5
FORGE_WS_MAX_PAYLOAD_BYTES=16384
FORGE_WS_MAX_QUEUE_BYTES=262144
FORGE_WS_MAX_SUBSCRIPTIONS=8
FORGE_WS_MESSAGE_RATE_MAX=30
FORGE_WS_MESSAGE_RATE_WINDOW_MS=10000

# Sentinel
SENTINEL_DB_PATH=./data/sentinel.sqlite
SENTINEL_UPSTREAM_URL=http://localhost:3000/mcp
SENTINEL_UPSTREAM_COMMAND=
# Audit redaction is always enabled. Fingerprints are optional and non-reversible.
SENTINEL_AUDIT_RETENTION_DAYS=30
SENTINEL_AUDIT_MAX_REQUEST_BYTES=65536
SENTINEL_AUDIT_MAX_ERROR_BYTES=4096
SENTINEL_AUDIT_FINGERPRINT_SECRETS=false
# Durable approvals fail closed. Channel adapters are registered by embedding applications.
SENTINEL_APPROVAL_CHANNELS=default
SENTINEL_APPROVAL_TIMEOUT=5m
SENTINEL_APPROVER_PRINCIPAL=sentinel-approver

# Atlas
ATLAS_DB_PATH=./data/atlas.sqlite
ATLAS_PORT=4003
# Comma-separated exact absolute executables allowed for stdio MCP health probes.
ATLAS_HEALTH_STDIO_COMMANDS=

# Bridge
BRIDGE_TRUSTED_PRIVATE_HOSTS=

# Composer
COMPOSER_CONFIG=./composer.yml

# Observatory
OBSERVATORY_DB_PATH=./data/observatory.sqlite
OBSERVATORY_PORT=4006

# Publishing
NPM_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=your-org/mcp-suite
