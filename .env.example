# Shared
NODE_ENV=development
LOG_LEVEL=info

# Forge
FORGE_DB_PATH=./data/forge.sqlite

# Sentinel
SENTINEL_DB_PATH=./data/sentinel.sqlite
SENTINEL_UPSTREAM_URL=http://localhost:3000/mcp
SENTINEL_UPSTREAM_COMMAND=
# Audit redaction is always enabled. Fingerprints are optional and non-reversible.
SENTINEL_AUDIT_RETENTION_DAYS=30
SENTINEL_AUDIT_MAX_REQUEST_BYTES=65536
SENTINEL_AUDIT_MAX_ERROR_BYTES=4096
SENTINEL_AUDIT_FINGERPRINT_SECRETS=false

# Atlas
ATLAS_DB_PATH=./data/atlas.sqlite
ATLAS_PORT=4003

# Composer
COMPOSER_CONFIG=./composer.yml

# Observatory
OBSERVATORY_DB_PATH=./data/observatory.sqlite
OBSERVATORY_PORT=4006

# Publishing
NPM_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=your-org/mcp-suite
